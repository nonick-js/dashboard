{
  "name": "nonick.js-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build && pnpm prisma:generate && pnpm prisma:db",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate --schema src/database/prisma/schema.prisma",
    "prisma:generate-dev": "dotenv -e .env.local -- prisma generate --schema src/database/prisma/schema.prisma",
    "prisma:db": "prisma db push --schema src/database/prisma/schema.prisma",
    "prisma:db-dev": "dotenv -e .env.local -- prisma db push --schema src/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^9.4.1",
    "@nextui-org/react": "^2.2.10",
    "@prisma/client": "^5.12.1",
    "framer-motion": "^11.0.28",
    "next": "14.1.4",
    "next-auth": "5.0.0-beta.16",
    "next-themes": "^0.3.0",
    "prisma": "^5.12.1",
    "react": "^18",
    "react-dom": "^18",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "1.6.4",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "dotenv-cli": "^7.4.1",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
