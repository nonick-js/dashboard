{
  "name": "nonick.js-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build && pnpm prisma:generate && pnpm prisma:db",
    "start": "next start",
    "lint": "next lint",
    "prisma:generate": "prisma generate --schema src/database/prisma/schema.prisma",
    "prisma:db": "prisma db push --schema src/database/prisma/schema.prisma",
    "prisma:generate-local": "dotenv -e .env.local -- prisma generate --schema src/database/prisma/schema.prisma",
    "prisma:db-local": "dotenv -e .env.local -- prisma db push --schema src/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@icons-pack/react-simple-icons": "^9.4.1",
    "@nextui-org/react": "^2.2.10",
    "@prisma/client": "^5.12.1",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "class-variance-authority": "^0.7.0",
    "framer-motion": "^11.0.28",
    "next": "14.2.1",
    "next-auth": "5.0.0-beta.16",
    "next-themes": "^0.3.0",
    "nextjs-toploader": "^1.6.11",
    "nprogress": "^0.2.0",
    "prisma": "^5.12.1",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.51.3",
    "react-responsive": "^10.0.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "1.6.4",
    "@iconify-icon/react": "^2.0.1",
    "@types/node": "^20",
    "@types/nprogress": "^0.2.3",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "discord-api-types": "^0.37.79",
    "dotenv-cli": "^7.4.1",
    "postcss": "^8",
    "tailwindcss": "^3.3.0",
    "typescript": "^5"
  }
}
